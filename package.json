{
  "name": "decoders-markdown",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "cross-env NF_TARGET=shell ng serve decoders-markdown",
    "start:markdown-studio": "cross-env NF_TARGET=remote ng serve markdown-studio-remote",
    "build": "cross-env NF_TARGET=shell ng build decoders-markdown",
    "build:markdown-studio": "cross-env NF_TARGET=remote ng build markdown-studio-remote",
    "build:all": "npm run build && npm run build:markdown-studio",
    "watch": "cross-env NF_TARGET=shell ng build decoders-markdown --watch --configuration development",
    "test": "ng test decoders-markdown"
  },
  "private": true,
  "packageManager": "npm@11.6.2",
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@lucide/angular": "^1.23.0",
    "@types/d3": "^7.4.3",
    "d3": "^7.9.0",
    "es-module-shims": "^1.10.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "unified": "^11.0.5"
  },
  "devDependencies": {
    "@angular-architects/native-federation": "^21.2.5",
    "@angular/build": "^21.2.19",
    "@angular/cli": "^21.2.19",
    "@angular/compiler-cli": "^21.2.0",
    "@types/mdast": "^4.0.4",
    "@types/unist": "^3.0.3",
    "cross-env": "^10.1.0",
    "jsdom": "^28.0.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
