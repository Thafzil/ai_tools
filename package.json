{
  "name": "decoders-markdown",
  "version": "0.0.0",
  "scripts": {
    "api": "tsx backend/src/server.ts",
    "api:check": "tsc -p backend/tsconfig.json --noEmit",
    "ng": "ng",
    "start": "cross-env NF_TARGET=shell ng serve decoders-markdown",
    "start:markdown-studio": "cross-env NF_TARGET=markdown ng serve markdown-studio-remote",
    "start:neatcode": "cross-env NF_TARGET=neatcode ng serve neatcode-remote",
    "build": "cross-env NF_TARGET=shell ng build decoders-markdown",
    "build:markdown-studio": "cross-env NF_TARGET=markdown ng build markdown-studio-remote",
    "build:neatcode": "cross-env NF_TARGET=neatcode ng build neatcode-remote",
    "build:all": "npm run build && npm run build:markdown-studio && npm run build:neatcode",
    "watch": "cross-env NF_TARGET=shell ng build decoders-markdown --watch --configuration development",
    "test": "ng test decoders-markdown"
  },
  "private": true,
  "packageManager": "npm@11.6.2",
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@lucide/angular": "^1.23.0",
    "@types/d3": "^7.4.3",
    "cors": "^2.8.6",
    "d3": "^7.9.0",
    "dotenv": "^17.4.2",
    "es-module-shims": "^1.10.1",
    "express": "^5.2.1",
    "mongoose": "^9.7.4",
    "openai": "^6.47.0",
    "prettier": "^3.9.5",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "unified": "^11.0.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@angular-architects/native-federation": "^21.2.5",
    "@angular/build": "^21.2.19",
    "@angular/cli": "^21.2.19",
    "@angular/compiler-cli": "^21.2.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/mdast": "^4.0.4",
    "@types/node": "^26.1.1",
    "@types/unist": "^3.0.3",
    "cross-env": "^10.1.0",
    "jsdom": "^28.0.0",
    "tsx": "^4.23.1",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
