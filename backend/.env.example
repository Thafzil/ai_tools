PORT=5050
NODE_ENV=development
CORS_ORIGIN=http://127.0.0.1:4200,http://localhost:4200,http://127.0.0.1:4301,http://localhost:4301,http://127.0.0.1:4302,http://localhost:4302
SESSION_SECRET=replace-with-a-long-random-secret

# A full URI is required for MongoDB. User/password alone are not enough because
# Mongo also needs the host or Atlas cluster address.
MONGO_URI=mongodb+srv://<user>:<password>@<cluster-host>/neatcode?retryWrites=true&w=majority
# Or provide the pieces below and leave MONGO_URI unset.
MONGO_HOST=<cluster-host>
MONGO_USER=<user>
MONGO_PASSWORD=<password>
MONGO_DB_NAME=neatcode

# Set false when you want the API to refuse startup unless MongoDB is connected.
ALLOW_MEMORY_FALLBACK=true

# Local Ollama through the OpenAI-compatible API.
LLM_PROVIDER=ollama
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=ollama
LLM_MODEL=llama3.2:latest
LLM_TIMEOUT_MS=90000
