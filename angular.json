{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "cli": {
    "packageManager": "npm"
  },
  "newProjectRoot": "projects",
  "projects": {
    "decoders-markdown": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "style": "scss"
        }
      },
      "root": "",
      "sourceRoot": "src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular-architects/native-federation:build",
          "options": {},
          "configurations": {
            "production": {
              "target": "decoders-markdown:esbuild:production"
            },
            "development": {
              "target": "decoders-markdown:esbuild:development",
              "dev": true
            }
          },
          "defaultConfiguration": "production"
        },
        "esbuild": {
          "builder": "@angular/build:application",
          "options": {
            "browser": "src/main.ts",
            "polyfills": ["es-module-shims"],
            "tsConfig": "tsconfig.app.json",
            "inlineStyleLanguage": "scss",
            "allowedCommonJsDependencies": ["extend"],
            "assets": [
              {
                "glob": "**/*",
                "input": "public"
              }
            ],
            "styles": ["src/styles.scss"]
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "500kB",
                  "maximumError": "1MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "18kB",
                  "maximumError": "24kB"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular-architects/native-federation:build",
          "options": {
            "target": "decoders-markdown:serve-original:development",
            "rebuildDelay": 500,
            "dev": true,
            "port": 0
          }
        },
        "serve-original": {
          "builder": "@angular/build:dev-server",
          "options": {
            "host": "127.0.0.1",
            "port": 4200
          },
          "configurations": {
            "production": {
              "buildTarget": "decoders-markdown:esbuild:production"
            },
            "development": {
              "buildTarget": "decoders-markdown:esbuild:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "test": {
          "builder": "@angular/build:unit-test",
          "options": {
            "buildTarget": "decoders-markdown:esbuild:development"
          }
        }
      }
    },
    "markdown-studio-remote": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "style": "scss"
        }
      },
      "root": "",
      "sourceRoot": "src",
      "prefix": "markdown-studio",
      "architect": {
        "build": {
          "builder": "@angular-architects/native-federation:build",
          "options": {},
          "configurations": {
            "production": {
              "target": "markdown-studio-remote:esbuild:production"
            },
            "development": {
              "target": "markdown-studio-remote:esbuild:development",
              "dev": true
            }
          },
          "defaultConfiguration": "production"
        },
        "esbuild": {
          "builder": "@angular/build:application",
          "options": {
            "browser": "src/markdown-studio/main.ts",
            "index": "src/markdown-studio/index.html",
            "polyfills": ["es-module-shims"],
            "tsConfig": "tsconfig.app.json",
            "inlineStyleLanguage": "scss",
            "allowedCommonJsDependencies": ["extend"],
            "assets": [
              {
                "glob": "**/*",
                "input": "public"
              }
            ],
            "styles": ["src/styles.scss"],
            "outputPath": "dist/markdown-studio-remote"
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "500kB",
                  "maximumError": "1MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "18kB",
                  "maximumError": "24kB"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular-architects/native-federation:build",
          "options": {
            "target": "markdown-studio-remote:serve-original:development",
            "rebuildDelay": 500,
            "dev": true,
            "port": 0
          }
        },
        "serve-original": {
          "builder": "@angular/build:dev-server",
          "options": {
            "host": "127.0.0.1",
            "port": 4301
          },
          "configurations": {
            "production": {
              "buildTarget": "markdown-studio-remote:esbuild:production"
            },
            "development": {
              "buildTarget": "markdown-studio-remote:esbuild:development"
            }
          },
          "defaultConfiguration": "development"
        }
      }
    }
  }
}
